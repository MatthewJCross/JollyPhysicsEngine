<Window x:Class="JollyPhysicsEngine.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JollyPhysicsEngine"
        mc:Ignorable="d"
        Title="Jolly Physics Engine Demo" Height="700" Width="1000" Loaded="Window_Loaded" WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="34" />
    </WindowChrome.WindowChrome>

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" CanExecute="CommandBinding_CanExecute" Executed="CommandBinding_Executed_Close" />
        <CommandBinding Command="{x:Static SystemCommands.MaximizeWindowCommand}" CanExecute="CommandBinding_CanExecute" Executed="CommandBinding_Executed_Maximize" />
        <CommandBinding Command="{x:Static SystemCommands.MinimizeWindowCommand}" CanExecute="CommandBinding_CanExecute" Executed="CommandBinding_Executed_Minimize" />
        <CommandBinding Command="{x:Static SystemCommands.RestoreWindowCommand}" CanExecute="CommandBinding_CanExecute" Executed="CommandBinding_Executed_Restore" />
    </Window.CommandBindings>

    <Border x:Name="mainWindowBorder" Margin="0,0,0,0" BorderBrush="Black" BorderThickness="2,2,2,2" CornerRadius="10,10,0,0" Background="#FF005994">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height ="36"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Image Name="systemSelect" Source="/PhyEng.ico" Width="32" Height="32" Margin="2" HorizontalAlignment="Left" VerticalAlignment="Center" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Image.Style>
                            <Style TargetType="{x:Type Image}">
                                <Setter Property="Opacity" Value="0.9"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <TextBlock Name="textBlockHeading" Text="Jolly Physics Engine Demo" FontFamily="Comic Sans MS" Margin="6,3,0,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="22" Foreground="White" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1">
                    <Button Style="{StaticResource MinimizeButtonStyle}" WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="Minimize" Command="{x:Static SystemCommands.MinimizeWindowCommand}"/>
                    <Button x:Name="RestoreButton" Visibility="Collapsed" Style="{StaticResource RestoreButtonStyle}" Command="{x:Static SystemCommands.RestoreWindowCommand}" WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="Restore"/>
                    <Button x:Name="MaximizeButton" Visibility="Visible" Style="{StaticResource MaximizeButtonStyle}" Command="{x:Static SystemCommands.MaximizeWindowCommand}" WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="Maximize" />
                    <Button Style="{StaticResource CloseButtonStyle}" WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="Close" Command="{x:Static SystemCommands.CloseWindowCommand}"/>
                </StackPanel>


            </Grid>

            <Separator Grid.Row="1" VerticalAlignment="Top"/>

            <!-- Toolbar -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5" Background="#F0F0F0">
                <Button x:Name="btnAddBall" Content="Add Ball" Width="80" Margin="5" Click="btnAddBall_Click" Style="{StaticResource RoundButton}"/>
                <Button x:Name="btnAddBox" Content="Add Box" Width="80" Margin="5" Click="btnAddBox_Click" Style="{StaticResource RoundButton}"/>
                <Button x:Name="btnAddTriangle" Content="Add Triangle" Width="80" Margin="5" Click="btnAddTriangle_Click" Style="{StaticResource RoundButton}"/>
                <Button x:Name="btnAddPolygon" Content="Add Polygon" Width="80" Margin="5" Click="btnAddPolygon_Click" Style="{StaticResource RoundButton}"/>
                <ComboBox x:Name="cmbPolygonSides" Width="60" Margin="5" SelectedIndex="2">
                    <ComboBoxItem Content="3"/>
                    <ComboBoxItem Content="4"/>
                    <ComboBoxItem Content="5"/>
                    <ComboBoxItem Content="6"/>
                    <ComboBoxItem Content="7"/>
                    <ComboBoxItem Content="8"/>
                    <ComboBoxItem Content="10"/>
                    <ComboBoxItem Content="12"/>
                    <ComboBoxItem Content="15"/>
                    <ComboBoxItem Content="20"/>
                </ComboBox>
                <Button x:Name="btnClear" Content="Clear" Width="80" Margin="5" Click="btnClear_Click" Style="{StaticResource RoundButton}"/>
                <Button x:Name="btnPause" Content="Pause" Width="80" Margin="5" Click="btnPause_Click" Style="{StaticResource RoundButton}"/>
                <CheckBox x:Name="chkGravity" Content="Gravity" Margin="10,9" IsChecked="True"/>
                <CheckBox x:Name="chkCollisions" Content="Collisions" Margin="10,9" IsChecked="True"/>
                <TextBlock Text="Objects:" Margin="10,3,5,5" VerticalAlignment="Center"/>
                <TextBlock x:Name="txtObjectCount" Text="0" Margin="5" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Physics Canvas -->
            <Border Grid.Row="2" BorderBrush="Black" BorderThickness="2" Margin="5,0,5,5" Background="Bisque">
                <Canvas x:Name="physicsCanvas" Background="Bisque" MouseLeftButtonDown="physicsCanvas_MouseLeftButtonDown" MouseMove="physicsCanvas_MouseMove" MouseLeftButtonUp="physicsCanvas_MouseLeftButtonUp"/>
            </Border>

            <!-- Status Bar -->
            <StatusBar Grid.Row="3" VerticalAlignment="Bottom" Background="#E0E0E0">
                <StatusBarItem>
                    <TextBlock x:Name="txtStatus" Text="Ready"/>
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </Border>
</Window>
